---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Sendblue MCP | SMS/iMessage for AI agents"
  description="Your agent needs to send messages and check replies. No webhooks, no exposed endpoints, no security risk. Polling-based SMS/iMessage via Sendblue API."
>

  <Nav currentPage="sendblue" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 40px;">
    <div class="container-narrow" style="text-align: center;">
      <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-ink-quaternary); margin-bottom: 1rem;">Open source &middot; MIT license &middot; MCP server</div>
      <h1 style="font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        SMS/iMessage for<br/><span style="color: var(--color-accent);">AI agents.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.6; max-width: 500px; margin: 0 auto 2rem;">
        Your agent sends campaign messages and checks for replies. No webhooks. No exposed endpoints. No security risk. Just secure API polling.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/sendblue-mcp" class="btn btn-accent" style="padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none;">View on GitHub</a>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">Why not webhooks?</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 600px; margin: 0 auto 1.5rem; text-align: center;">
        Traditional webhook approaches require exposing your machine to the internet &mdash; via ngrok, Tailscale, or a public server. That's an attack surface on the machine where your credentials, code, and agent memory live.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; margin-top: 2rem;">
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">No exposed services</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Your machine makes outbound HTTPS calls only. Nothing listens. Nothing is reachable from the internet.</div>
        </div>
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">No infrastructure</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">No ngrok. No Tailscale Funnel. No webhook receiver. No static IP needed. Works from anywhere.</div>
        </div>
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Polling is enough</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Campaign responses take hours or days. Checking every few minutes is fast enough. Zero complexity for the same result.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- What it looks like -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">What it looks like</h2>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Send a message</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">send_sms</span>(number="+15551234567", content="Campaign message here")</div>
          <div style="color: #a1a1aa;">&rarr; {`{"status": "QUEUED", "message_handle": "35d2bd01..."}`}</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Check for replies</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">list_messages</span>(is_outbound=False, limit=10)</div>
          <div style="color: #a1a1aa;">&rarr; {`[{"content": "Interested!", "from_number": "+15551234567", ...}]`}</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Check iMessage support</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">evaluate_service_type</span>(number="+15551234567")</div>
          <div style="color: #a1a1aa;">&rarr; {`{"number": "+15551234567", "service": "iMessage"}`}</div>
        </div>
      </div>

      <div>
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Get your contacts</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">get_contacts</span>()</div>
          <div style="color: #a1a1aa;">&rarr; {`[{"name": "alice", "number": "+15551234567"}, {"name": "bob", "number": "+15559998888"}]`}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- End-to-end -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">End-to-end: a sales campaign</h2>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.75rem;">Monday &mdash; Campaign launch</div>
        <div class="code-block">
          <div style="color: #71717a;"># Agent sends 50 outreach messages</div>
          <div>for contact in campaign_list:</div>
          <div>&nbsp;&nbsp;&nbsp;&nbsp;<span style="color: #4ade80;">send_sms</span>(number=contact.phone, content=personalized_message)</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.75rem;">Tuesday &mdash; Check responses</div>
        <div class="code-block">
          <div style="color: #71717a;"># Different session, different agent</div>
          <div>replies = <span style="color: #4ade80;">list_messages</span>(is_outbound=False, limit=50)</div>
          <div style="color: #a1a1aa;"># 12 replies, 3 interested, 9 opt-outs</div>
        </div>
        <p style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.5rem;">No webhook setup. No public endpoints. No ngrok. Just secure API polling.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">How it works</h2>
      <div style="max-width: 560px; margin: 0 auto;">
        <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.25rem;">
          Sendblue MCP is a FastMCP server backed by httpx for async API calls. Your agent talks to the MCP server. The MCP server talks to Sendblue over HTTPS. Nothing listens. Nothing is exposed.
        </p>
        <div class="code-block" style="margin-bottom: 1.5rem;">
          <div style="color: #a1a1aa;">Agent &rarr; MCP Server (FastMCP) &rarr; Sendblue API (HTTPS)</div>
        </div>
        <ul style="list-style: none; padding: 0; display: grid; gap: 0.75rem;">
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">01</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Credentials stored locally in <code style="font-family: var(--font-mono); font-size: 0.8125rem; background: rgba(0,0,0,0.05); padding: 0.15em 0.4em; border-radius: 4px;">~/.keys/sendblue.json</code> (mode 0600)</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">02</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">All API calls are outbound-only HTTPS &mdash; nothing inbound, nothing exposed</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">03</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Five tools: send, list messages, get contacts, check delivery status, evaluate iMessage support</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">04</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Works with Windsurf, Claude Desktop, or any MCP-compatible client</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Install</h2>
      <div style="max-width: 560px; margin: 0 auto;">
        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Clone and install</div>
          <div class="code-block">
            <div><span style="color: #4ade80;">$</span> git clone https://github.com/jackccrawford/sendblue-mcp.git</div>
            <div><span style="color: #4ade80;">$</span> cd sendblue-mcp</div>
            <div><span style="color: #4ade80;">$</span> poetry install --no-root</div>
          </div>
        </div>

        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Configure credentials</div>
          <div class="code-block">
            <div style="color: #71717a;">// ~/.keys/sendblue.json</div>
            <div>{`{`}</div>
            <div>&nbsp;&nbsp;"api_key": "<span style="color: #a1a1aa;">your_sendblue_api_key</span>",</div>
            <div>&nbsp;&nbsp;"secret_key": "<span style="color: #a1a1aa;">your_sendblue_secret_key</span>",</div>
            <div>&nbsp;&nbsp;"from_number": "<span style="color: #4ade80;">+15559876543</span>",</div>
            <div>&nbsp;&nbsp;"contacts": {`{ "alice": "+15551234567" }`}</div>
            <div>{`}`}</div>
          </div>
          <p style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.5rem;">Get credentials from <a href="https://app.sendblue.co" style="color: var(--color-accent); text-decoration: underline;">Sendblue Dashboard</a></p>
        </div>

        <div>
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Add to Claude Desktop</div>
          <div class="code-block">
            <div style="color: #71717a;">// claude_desktop_config.json</div>
            <div>{`{`}</div>
            <div>&nbsp;&nbsp;"mcpServers": {`{`}</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;"sendblue": {`{`}</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"command": "<span style="color: #4ade80;">poetry</span>",</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"args": ["-C", "/path/to/sendblue-mcp", "run", "python", "src/server.py"]</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;{`}`}</div>
            <div>&nbsp;&nbsp;{`}`}</div>
            <div>{`}`}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1rem;">
        Your agent needs to<br/>reach people.
      </h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); margin-bottom: 2rem;">
        Secure SMS/iMessage. No webhooks. No attack surface.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/sendblue-mcp" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: var(--color-surface-dark); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: opacity 0.15s;" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
      <p style="font-size: 0.8125rem; color: var(--color-ink-quaternary); margin-top: 1.5rem;">MIT License &middot; Python &middot; FastMCP &middot; Works with Claude Desktop &amp; Windsurf</p>
    </div>
  </section>

  <Footer />

</Layout>
