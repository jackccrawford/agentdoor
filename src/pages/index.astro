---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AgentDoor | Your AI agent forgets everything. We fix that." description="Open source tools that give AI agents persistent memory, model choice, and secure messaging. Install in seconds. No cloud. No API key.">

  <Nav currentPage="home" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 40px;">
    <div class="container-narrow" style="text-align: center;">
      <h1 style="font-size: clamp(2.5rem, 5.5vw, 3.75rem); font-weight: 700; line-height: 1.08; letter-spacing: -0.035em; margin-bottom: 1.5rem;">
        Your AI agent forgets<br/>everything between sessions.<br/><span style="color: var(--color-accent);">That's fixable.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 540px; margin: 0 auto 2rem;">
        You brief your agent. It does great work. The session ends. Next session &mdash; it asks the same questions again. Every insight, every preference, every decision &mdash; gone.
      </p>
      <p style="font-size: 1.125rem; color: var(--color-ink); line-height: 1.7; max-width: 540px; margin: 0 auto 2.5rem; font-weight: 500;">
        We build open source tools that let agents remember.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="/geniuz" class="btn btn-accent" style="padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none;">Get Geniuz for Claude Desktop</a>
        <a href="/clawmark" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 1rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          Clawmark for developers
        </a>
      </div>
    </div>
  </section>

  <!-- The problem, visualized -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="container-narrow" style="max-width: 600px; margin: 0 auto;">

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1rem;">
        <!-- Without -->
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-quaternary); margin-bottom: 1rem;">Without memory</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.7;">
            <p style="margin: 0 0 0.75rem;">&ldquo;What's your budget?&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;What did we decide last time?&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;Can you explain the project again?&rdquo;</p>
            <p style="margin: 0; color: var(--color-ink-tertiary); font-style: italic;">Every. Single. Session.</p>
          </div>
        </div>
        <!-- With -->
        <div style="padding: 1.5rem; border: 1px solid var(--color-accent); border-radius: 12px; background: rgba(249,115,22,0.03);">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-accent); margin-bottom: 1rem;">With Geniuz</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink); line-height: 1.7;">
            <p style="margin: 0 0 0.75rem;">&ldquo;Based on your $40K budget and Q2 retention focus&hellip;&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;Last session we decided to start with scheduling&hellip;&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;Elena handles invoicing &mdash; copying her on this.&rdquo;</p>
            <p style="margin: 0; color: var(--color-accent); font-weight: 500;">Picks up where it left off.</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Clawmark — the main product -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <div style="max-width: 600px; margin: 0 auto;">
        <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 0.75rem;">For developers</div>
        <h2 style="font-size: 1.75rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem;">Clawmark &mdash; the engine under Geniuz.</h2>
        <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
          One binary. One command to save. One command to search. Finds things by meaning, not keywords &mdash; so &ldquo;budget priorities&rdquo; matches a note about &ldquo;retention focus, $40K.&rdquo;
        </p>
        <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
          Works with Claude Code, OpenClaw, Cursor, Windsurf, Aider, or any agent that can run a shell command. No cloud. No API key. No account. Your data stays on your machine.
        </p>

        <div class="code-block" style="margin-bottom: 1.5rem;">
          <div><span style="color: #4ade80;">$</span> curl -fsSL https://raw.githubusercontent.com/jackccrawford/clawmark/main/install.sh | bash</div>
        </div>

        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
          <a href="/clawmark" style="padding: 0.75rem 1.5rem; background: var(--color-accent); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9375rem; transition: opacity 0.15s;" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">See how it works &rarr;</a>
          <a href="https://github.com/jackccrawford/clawmark" style="padding: 0.75rem 1.5rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-weight: 500; font-size: 0.9375rem; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">View on GitHub</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Built for people who use AI every day</h2>
      <div style="max-width: 620px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem;">
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Business owners</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Your agent remembers client preferences, project history, and decisions across weeks of conversations.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Researchers</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Build a searchable library of findings. Ask &ldquo;what did I read about attention mechanisms?&rdquo; and get answers by meaning.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Developers</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Stop re-explaining your codebase. Your agent remembers the architecture decisions, the bug fixes, the edge cases.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Writers &amp; creators</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Maintain voice and continuity across chapters, drafts, and revisions &mdash; even weeks apart.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Other tools -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">More tools for agents</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; max-width: 620px; margin: 0 auto;">

        <a href="/token-scout" style="text-decoration: none; color: inherit; display: block; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px; background: white; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <h3 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem;">Token Scout</h3>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin-bottom: 0.75rem;">Find free LLM models. Your agent discovers and uses models across providers &mdash; no proxy, no middleware.</p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">Learn more &rarr;</div>
        </a>

        <a href="/sendblue" style="text-decoration: none; color: inherit; display: block; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px; background: white; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <h3 style="font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem;">Sendblue MCP</h3>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin-bottom: 0.75rem;">SMS and iMessage for AI agents. Secure polling &mdash; no exposed endpoints, no webhooks, no attack surface.</p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">Learn more &rarr;</div>
        </a>

      </div>
    </div>
  </section>

  <!-- Open source + about -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px;">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">Open source. MIT licensed.</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 500px; margin: 0 auto 1.5rem;">
        No vendor lock-in. No API keys. Run locally, inspect everything, contribute back. Built by <a href="https://mvara.ai" style="color: var(--color-ink); font-weight: 500; text-decoration: underline;">mVara</a> &mdash; we build with AI agents every day and ship the tools we wish existed.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/clawmark" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Clawmark
        </a>
        <a href="https://github.com/jackccrawford/token-scout" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Token Scout
        </a>
        <a href="https://github.com/jackccrawford/sendblue-mcp" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Sendblue MCP
        </a>
      </div>
    </div>
  </section>

  <Footer />

</Layout>
