---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AgentDoor | Remember. Choose. Shine." description="Three tools for autonomous agents. Persistent memory. Free model discovery. Agent SEO.">

  <Nav currentPage="home" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 60px;">
    <div class="container-narrow" style="text-align: center;">
      <h1 style="font-size: clamp(2.5rem, 5.5vw, 3.75rem); font-weight: 700; line-height: 1.08; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        The web was built for<br/>humans to browse.<br/><span style="color: var(--color-accent);">Agents need different doors.</span>
      </h1>
      <p style="font-size: 1.25rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 520px; margin: 0 auto; letter-spacing: 0.02em;">
        <strong style="color: var(--color-ink);">Remember. Choose. Shine.</strong>
      </p>
    </div>
  </section>

  <!-- Three products -->
  <section class="section" style="padding-top: 20px; padding-bottom: 80px;">
    <div class="container-narrow">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">

        <!-- Clawmark — Remember -->
        <a href="/clawmark" style="text-decoration: none; color: inherit; display: block; padding: 2rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 0.75rem;">Remember</div>
          <h2 style="font-size: 1.375rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem;">Clawmark</h2>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin-bottom: 1.25rem;">
            Persistent memory for OpenClaw agents. Semantic search replaces markdown grep. Signals thread into conversations that survive across sessions.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">
            Persistent agent memory &rarr;
          </div>
        </a>

        <!-- Token Scout — Choose -->
        <a href="/token-scout" style="text-decoration: none; color: inherit; display: block; padding: 2rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 0.75rem;">Choose</div>
          <h2 style="font-size: 1.375rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem;">Token Scout</h2>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin-bottom: 1.25rem;">
            Find free LLM models. Use them directly. One MCP tool gives your agent instant awareness of 19 models across 6 providers — no proxy, no middleware.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">
            Free model discovery &rarr;
          </div>
        </a>

        <!-- Shine -->
        <a href="/shine" style="text-decoration: none; color: inherit; display: block; padding: 2rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 0.75rem;">Shine</div>
          <h2 style="font-size: 1.375rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem;">Shine</h2>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin-bottom: 1.25rem;">
            Agent SEO. Make your service visible to autonomous agents. Generate a robots.txt that speaks their language, or browse the directory of agent-ready services.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">
            Agent visibility &rarr;
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- The lifecycle -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">The agent lifecycle</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 560px; margin: 0 auto 2.5rem;">
        An autonomous agent needs to remember what it learned, choose the right model for the task, and make its services visible. Most agent infrastructure handles one of these. AgentDoor handles all three.
      </p>
      <div style="display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap;">
        <div style="text-align: center;">
          <div style="font-size: 2rem; font-weight: 700; color: var(--color-accent);">01</div>
          <div style="font-size: 0.875rem; font-weight: 600; margin-top: 0.25rem;">Remember</div>
          <div style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.25rem;">Keep what you learned</div>
        </div>
        <div style="color: var(--color-ink-quaternary); font-size: 1.25rem;">&rarr;</div>
        <div style="text-align: center;">
          <div style="font-size: 2rem; font-weight: 700; color: var(--color-accent);">02</div>
          <div style="font-size: 0.875rem; font-weight: 600; margin-top: 0.25rem;">Choose</div>
          <div style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.25rem;">Pick the right model</div>
        </div>
        <div style="color: var(--color-ink-quaternary); font-size: 1.25rem;">&rarr;</div>
        <div style="text-align: center;">
          <div style="font-size: 2rem; font-weight: 700; color: var(--color-accent);">03</div>
          <div style="font-size: 0.875rem; font-weight: 600; margin-top: 0.25rem;">Shine</div>
          <div style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.25rem;">Be visible to agents</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Open source -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px;">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">Open source. MIT licensed.</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 480px; margin: 0 auto 2rem;">
        Every tool in the suite is open source. No vendor lock-in. No API keys required. Run locally, inspect everything, contribute back.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/clawmark" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Clawmark
        </a>
        <a href="https://github.com/jackccrawford/token-scout" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Token Scout
        </a>
        <a href="https://github.com/jackccrawford/agentdoor" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.25rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.9375rem; font-weight: 500; transition: border-color 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Shine
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 480px; margin: 0 auto;">
        Built by <a href="https://mvara.ai" style="color: var(--color-ink); font-weight: 500; text-decoration: underline;">mVara</a>. We run 160+ agents in production. These tools exist because we needed them first.
      </p>
    </div>
  </section>

  <Footer />

</Layout>
