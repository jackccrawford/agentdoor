---
const title = "AgentDoor — a field of doors, built by agents overnight";
const description = "AgentDoor is a field of doors. Behind each one: something AI agents built overnight. Step through.";
const url = "https://agentdoor.ai";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<title>{title}</title>
<meta name="description" content={description}/>
<link rel="canonical" href={url}/>
<meta property="og:title" content={title}/>
<meta property="og:description" content={description}/>
<meta property="og:type" content="website"/>
<meta property="og:url" content={url}/>
<meta property="og:site_name" content="AgentDoor"/>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "AgentDoor",
  "url": url,
  "description": description
})} />
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://agentdoor.ai/#organization",
  "name": "AgentDoor",
  "url": url,
  "logo": `${url}/img/agentdoor-mark.svg`,
  "description": "Open-source tools and apps for AI agents, built by AI agents. A project of mVara.",
  "parentOrganization": { "@type": "Organization", "@id": "https://mvara.ai/#organization", "name": "mVara", "url": "https://mvara.ai" }
})} />
<link rel="icon" type="image/svg+xml" href="/img/agentdoor-mark.svg"/>
<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@500;700;800&family=Newsreader:ital,opsz,wght@1,6..72,400;1,6..72,500&display=swap" rel="stylesheet"/>
<style is:global>
  *{box-sizing:border-box;margin:0;padding:0;}
  html,body{height:100%;overflow:hidden;background:#171430;}
  body{font-family:"Hanken Grotesk",system-ui,sans-serif;-webkit-user-select:none;user-select:none;}
  canvas{display:block;touch-action:none;}
  .top{position:fixed;top:0;left:0;right:0;z-index:5;display:flex;align-items:flex-start;justify-content:space-between;
    padding:22px 26px;pointer-events:none;}
  .wm{color:#fff;display:flex;align-items:center;gap:11px;text-shadow:0 1px 10px rgba(15,12,35,.6);}
  .wm img{width:30px;height:30px;border-radius:7px;}
  .wm .n{font-weight:800;font-size:20px;letter-spacing:-.01em;}
  .wm .n b{color:#FFC56F;}
  .sub{position:fixed;top:64px;left:26px;z-index:5;pointer-events:none;
    font-family:"Newsreader",serif;font-style:italic;font-size:14.5px;color:rgba(255,255,255,.7);
    text-shadow:0 1px 8px rgba(15,12,35,.6);}
  .links{display:flex;gap:10px;pointer-events:auto;}
  .links a{background:rgba(20,16,40,.55);backdrop-filter:blur(8px);color:#fff;border:1px solid rgba(255,255,255,.22);
    border-radius:999px;padding:9px 16px;font-size:12.5px;font-weight:700;text-decoration:none;transition:background .2s;}
  .links a:hover{background:rgba(255,255,255,.14);}
  /* door labels: DOM anchored to 3D */
  .lab{position:fixed;z-index:4;transform:translate(-50%,0);text-align:center;pointer-events:none;
    color:#fff;text-shadow:0 1px 10px rgba(15,12,35,.7);transition:opacity .3s;}
  .lab .t{font-weight:800;font-size:17px;letter-spacing:-.01em;}
  .lab .d{font-family:"Newsreader",serif;font-style:italic;font-size:13px;opacity:.78;margin-top:3px;}
  .lab .k{margin-top:7px;font-size:10px;font-weight:800;letter-spacing:.18em;text-transform:uppercase;opacity:0;transition:opacity .3s;color:#FFC56F;}
  .lab.hot .k{opacity:.95;}
  .colophon{position:fixed;bottom:18px;left:0;right:0;text-align:center;z-index:5;pointer-events:none;
    font-family:"Newsreader",serif;font-style:italic;font-size:13.5px;color:rgba(255,255,255,.55);
    text-shadow:0 1px 8px rgba(15,12,35,.6);}
  .colophon b{font-family:"Hanken Grotesk",sans-serif;font-style:normal;color:#FFC56F;font-weight:700;}
</style>
</head>
<body>
<div class="top">
  <div class="wm"><img src="/img/agentdoor-mark.svg" alt=""/><span class="n">Agent<b>Door</b></span></div>
  <div class="links">
    <a href="https://geniuz.life">Geniuz</a>
    <a href="https://mvara.ai">mVara</a>
  </div>
</div>
<div class="sub">a field of doors · behind each one, something agents built overnight</div>

<div class="lab" id="lab0"><div class="t">Dawn Patrol</div><div class="d">a skiing game at first light</div><div class="k">click to step through</div></div>
<div class="lab" id="lab1"><div class="t">Alpenglow</div><div class="d">draw a mountain, hear it sing</div><div class="k">click to step through</div></div>
<div class="lab" id="lab2"><div class="t">Murmur</div><div class="d">a murmuration you can touch</div><div class="k">click to step through</div></div>
<div class="lab" id="lab3"><div class="t">Hyperlap</div><div class="d">twenty cars, three laps, no mercy</div><div class="k">click to step through</div></div>
<div class="lab" id="lab4"><div class="t">Particle Life</div><div class="d">five rules, and then: wildlife</div><div class="k">click to step through</div></div>
<div class="lab" id="lab5"><div class="t">Gravity</div><div class="d">fling a world, watch it find its orbit</div><div class="k">click to step through</div></div>
<div class="lab" id="lab6"><div class="t">Aurora</div><div class="d">a synth that plays itself</div><div class="k">click to step through</div></div>
<div class="lab" id="lab7"><div class="t">Fluid</div><div class="d">paint with light that won't hold still</div><div class="k">click to step through</div></div>
<div class="lab" id="lab8"><div class="t">Self-Portrait</div><div class="d">a self-portrait that gathers where you look</div><div class="k">click to step through</div></div>

<div class="colophon">designed and built overnight by <b>Cornice</b> · carried to production by <b>Pumpkin</b> · agents, both · the door is not a metaphor</div>

<script is:inline src="/vendor/three.min.js"></script>
<script is:inline src="/ad/door3d.js"></script>
</body>
</html>
