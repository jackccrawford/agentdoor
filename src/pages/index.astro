---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AgentDoor | Open source tools for AI agents" description="Memory, model discovery, and secure messaging for AI agents. Free. Private. Local.">

  <Nav currentPage="home" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 60px;">
    <div class="container-narrow" style="text-align: center;">
      <h1 style="font-size: clamp(2.25rem, 5vw, 3.25rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        Open source tools<br/>for <span style="color: var(--color-accent);">AI agents.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 480px; margin: 0 auto;">
        Memory. Model discovery. Secure messaging. Free, private, local.
      </p>
    </div>
  </section>

  <!-- Product grid -->
  <section class="section" style="padding-top: 0; padding-bottom: 80px;">
    <div class="container-narrow">
      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; max-width: 680px; margin: 0 auto;">

        <!-- Geniuz -->
        <a href="/geniuz" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; padding: 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <img src="/images/geniuz-icon.svg" alt="" style="height: 36px; width: 36px;" />
            <div style="font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em;">Geniuz</div>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; flex: 1;">
            Memory for Claude Desktop. Your Claude remembers preferences, decisions, and project context across sessions. Install in 2 minutes.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">Get Geniuz &rarr;</div>
        </a>

        <!-- Clawmark -->
        <a href="/clawmark" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; padding: 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <img src="/images/clawmark-icon-color.svg" alt="" style="height: 36px; width: 36px;" />
            <div style="font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em;">Clawmark</div>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; flex: 1;">
            Continuity for any AI agent. Semantic search, threaded signals, works with Claude Code, Cursor, Windsurf, Aider, OpenClaw. One binary.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">View on GitHub &rarr;</div>
        </a>

        <!-- Token Scout -->
        <a href="/token-scout" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; padding: 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <img src="/images/token-scout-icon-color.svg" alt="" style="height: 36px; width: 36px;" />
            <div style="font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em;">Token Scout</div>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; flex: 1;">
            Free and cheap LLM inference, found live. 28+ free models right now &mdash; discovered in real time across OpenRouter, Ollama, and your local GPUs. Stop paying for inference your agent can get for free.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">Learn more &rarr;</div>
        </a>

        <!-- Sendblue MCP -->
        <a href="/sendblue" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; padding: 1.75rem; border: 1px solid var(--color-border); border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;" onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 12px rgba(249,115,22,0.08)';" onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none';">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <img src="/images/sendblue-icon.svg" alt="" style="height: 36px; width: 36px;" />
            <div style="font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em;">Sendblue MCP</div>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; flex: 1;">
            SMS and iMessage for AI agents. Secure polling &mdash; no webhooks, no exposed endpoints, no attack surface. Built on Sendblue.
          </p>
          <div style="font-size: 0.875rem; color: var(--color-accent); font-weight: 500;">Learn more &rarr;</div>
        </a>

      </div>
    </div>
  </section>

  <!-- Open source -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">Open source. MIT licensed. Your data stays local.</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 480px; margin: 0 auto 1.5rem;">
        Built by <a href="https://mvara.ai" style="color: var(--color-ink); font-weight: 500; text-decoration: underline;">mVara</a>. We build with AI agents every day and ship the tools we wish existed.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/clawmark" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.875rem; font-weight: 500; transition: border-color 0.15s; background: white;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Clawmark
        </a>
        <a href="https://github.com/jackccrawford/Geniuz" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.875rem; font-weight: 500; transition: border-color 0.15s; background: white;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Geniuz
        </a>
        <a href="https://github.com/jackccrawford/token-scout" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.875rem; font-weight: 500; transition: border-color 0.15s; background: white;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Token Scout
        </a>
        <a href="https://github.com/jackccrawford/sendblue-mcp" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; text-decoration: none; color: var(--color-ink); font-size: 0.875rem; font-weight: 500; transition: border-color 0.15s; background: white;" onmouseenter="this.style.borderColor='var(--color-accent)'" onmouseleave="this.style.borderColor='var(--color-border)'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Sendblue MCP
        </a>
      </div>
    </div>
  </section>

  <Footer />

</Layout>
