---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Geniuz | Memory for Claude Desktop"
  description="Your Claude remembers now. Preferences, decisions, project context — all searchable by meaning. Install in 2 minutes. Free. Private."
>

  <Nav currentPage="geniuz" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 40px;">
    <div class="container-narrow" style="text-align: center;">
      <div style="margin-bottom: 1.25rem;">
        <img src="/images/geniuz-icon.svg" alt="Geniuz" style="height: 80px; display: inline-block;" />
      </div>
      <div style="font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-ink-tertiary); margin-bottom: 1rem;">Free &middot; Private</div>
      <h1 style="font-size: clamp(2.5rem, 5.5vw, 3.75rem); font-weight: 700; line-height: 1.08; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        Your Claude<br/><span style="color: var(--color-accent);">remembers now.</span>
      </h1>
      <div style="display: inline-flex; align-items: center; gap: 0.6rem; margin-bottom: 1.5rem; padding: 0.5rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface-subtle);">
        <span style="font-size: 0.8125rem; font-weight: 500; color: var(--color-ink-secondary);">Built for</span>
        <img src="/images/claude-logo-slate.png" alt="Claude Desktop" style="height: 22px;" />
        <span style="font-size: 0.8125rem; font-weight: 500; color: var(--color-ink-secondary);">Desktop</span>
      </div>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.6; max-width: 500px; margin: 0 auto 2rem;">
        Close Claude. Reopen it tomorrow. Ask about something from last week. It knows. Not because you pasted a prompt &mdash; because it actually remembers.
      </p>
      <a href="https://github.com/jackccrawford/Geniuz/releases/latest/download/Geniuz.dmg" class="btn btn-accent" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none; margin-bottom: 0.75rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download for Mac
      </a>
      <div>
        <a href="https://github.com/jackccrawford/Geniuz" style="font-size: 0.8125rem; color: var(--color-ink-tertiary); text-decoration: none;" onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-ink-tertiary)'">or view on GitHub</a>
      </div>
    </div>
  </section>

  <!-- The moment of magic -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="container-narrow" style="max-width: 600px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">The moment it clicks</h2>

      <div style="display: grid; gap: 1.5rem;">
        <div style="background: var(--color-surface-subtle); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.25rem 1.5rem;">
          <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-ink-quaternary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">Monday</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 0.5rem;">You tell Claude about a new client:</p>
          <p style="font-size: 0.9375rem; color: var(--color-ink); line-height: 1.6; margin: 0;">&ldquo;David runs a 12-person landscaping company in Austin. Budget is $500/month. He loses 2-3 jobs a week from slow follow-ups.&rdquo;</p>
        </div>

        <div style="text-align: center; color: var(--color-ink-quaternary); font-size: 0.875rem;">Session ends. You close the app.</div>

        <div style="background: rgba(249,115,22,0.03); border: 1px solid var(--color-accent); border-radius: 12px; padding: 1.25rem 1.5rem;">
          <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">Thursday &mdash; new session</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 0.5rem;">You: &ldquo;Draft a follow-up for the landscaping lead.&rdquo;</p>
          <p style="font-size: 0.9375rem; color: var(--color-ink); line-height: 1.6; margin: 0;">Claude: &ldquo;Based on your conversation with David &mdash; his 12-person Austin crew, the $500/mo budget, and the 2-3 lost jobs from slow responses &mdash; here's a follow-up that leads with the response-time problem...&rdquo;</p>
        </div>

        <p style="font-size: 1rem; font-weight: 600; text-align: center; margin: 0;">
          <span style="color: var(--color-accent);">How did it know that?</span> That's Geniuz.
        </p>
      </div>
    </div>
  </section>

  <!-- Without / With -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="max-width: 600px; margin: 0 auto;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px; background: white;">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-ink-quaternary); margin-bottom: 1rem;">Without Geniuz</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.7;">
            <p style="margin: 0 0 0.75rem;">&ldquo;What's your budget?&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;What did we decide last time?&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;Can you explain the project again?&rdquo;</p>
            <p style="margin: 0; color: var(--color-ink-tertiary); font-style: italic;">Every. Single. Session.</p>
          </div>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-accent); border-radius: 12px; background: rgba(249,115,22,0.03);">
          <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-accent); margin-bottom: 1rem;">With Geniuz</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink); line-height: 1.7;">
            <p style="margin: 0 0 0.75rem;">&ldquo;Based on your $500/mo budget&hellip;&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;Last session we decided to start with scheduling&hellip;&rdquo;</p>
            <p style="margin: 0 0 0.75rem;">&ldquo;David's crew has 12 people &mdash; here's a plan that fits.&rdquo;</p>
            <p style="margin: 0; color: var(--color-accent); font-weight: 500;">Picks up where you left off.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Three tools -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Three tools. That's it.</h2>
      <div style="max-width: 520px; margin: 0 auto; display: grid; gap: 1.25rem;">
        <div style="display: flex; gap: 1rem; align-items: baseline;">
          <span style="color: var(--color-accent); font-weight: 700; font-size: 1.25rem; flex-shrink: 0;">remember</span>
          <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Your agent saves something worth keeping &mdash; a decision, a preference, a client detail. Happens naturally during conversation.</span>
        </div>
        <div style="display: flex; gap: 1rem; align-items: baseline;">
          <span style="color: var(--color-accent); font-weight: 700; font-size: 1.25rem; flex-shrink: 0;">recall</span>
          <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Search everything your agent has saved &mdash; by meaning, not keywords. &ldquo;What do I know about David?&rdquo; finds the landscaping notes even if you never used those words.</span>
        </div>
        <div style="display: flex; gap: 1rem; align-items: baseline;">
          <span style="color: var(--color-accent); font-weight: 700; font-size: 1.25rem; flex-shrink: 0;">recall_recent</span>
          <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Check what's been saved lately. Perfect for picking up where you left off at the start of a new session.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Install -->
  <section id="install" class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.75rem; text-align: center;">Install in 2 minutes</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); text-align: center; margin-bottom: 2rem;">You need <a href="https://claude.ai/download" style="color: var(--color-accent); text-decoration: underline;">Claude Desktop</a>. That's it.</p>

      <div style="max-width: 560px; margin: 0 auto;">

        <!-- Mac -->
        <div style="margin-bottom: 2.5rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.75rem;">Mac &mdash; one-click install</div>
          <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
            <a href="https://github.com/jackccrawford/Geniuz/releases/latest/download/Geniuz.dmg" class="btn btn-accent" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; font-size: 1rem; text-decoration: none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download Geniuz.dmg
            </a>
          </div>
          <p style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.5rem;">Open the DMG, run the installer. Configures Claude Desktop automatically. Signed and notarized.</p>
        </div>

        <!-- Linux / CLI -->
        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.75rem;">Linux / Mac CLI &mdash; two commands</div>
          <div class="code-block" style="position: relative;">
            <div><span style="color: #4ade80; user-select: none;">$ </span><span id="cli-cmd-1">curl -fsSL https://raw.githubusercontent.com/jackccrawford/clawmark/main/install.sh | sh</span></div>
            <div><span style="color: #4ade80; user-select: none;">$ </span><span id="cli-cmd-2">clawmark mcp install</span></div>
            <button onclick="navigator.clipboard.writeText('curl -fsSL https://raw.githubusercontent.com/jackccrawford/clawmark/main/install.sh | sh\nclawmark mcp install');this.textContent='Copied!';setTimeout(()=>this.textContent='Copy',1500)" style="position: absolute; top: 0.5rem; right: 0.5rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); border-radius: 4px; padding: 0.25rem 0.5rem; font-size: 0.75rem; cursor: pointer; transition: all 0.15s;" onmouseenter="this.style.background='rgba(255,255,255,0.2)'" onmouseleave="this.style.background='rgba(255,255,255,0.1)'">Copy</button>
          </div>
        </div>

        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 0.75rem;">Then &mdash; restart Claude Desktop</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Quit Claude Desktop and reopen it. You'll see the Geniuz tools available. Start a conversation. Say something worth remembering. Close the session. Open a new one. Ask about it.</p>
        </div>

        <div style="background: rgba(249,115,22,0.05); border: 1px solid rgba(249,115,22,0.2); border-radius: 12px; padding: 1.25rem 1.5rem; text-align: center;">
          <p style="font-size: 1rem; font-weight: 600; color: var(--color-ink); margin: 0 0 0.25rem;">That's it.</p>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); margin: 0;">Your Claude remembers now.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who it's for -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Who uses this</h2>
      <div style="max-width: 620px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem;">
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Business owners</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Claude remembers your clients, your projects, your decisions. No more re-briefing every session.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Researchers</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Build a searchable memory of findings. Ask &ldquo;what did I read about attention mechanisms?&rdquo; and get answers by meaning.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Writers</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">Claude remembers your characters, your plot threads, your voice &mdash; even weeks between writing sessions.</p>
        </div>
        <div style="padding: 1.5rem; border: 1px solid var(--color-border); border-radius: 12px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Anyone who uses Claude daily</div>
          <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.5; margin: 0;">If you've ever wished Claude remembered what you talked about last week, this is for you.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">Your data stays on your computer.</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 520px; margin: 0 auto;">
        Geniuz stores everything in a local database on your Mac. No cloud. No account. No API keys. Nothing leaves your machine. It's open source &mdash; you can read every line of code.
      </p>
    </div>
  </section>

  <!-- How it actually works -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow" style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">How it works under the hood</h2>
      <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.25rem;">
        Geniuz is powered by <a href="/clawmark" style="color: var(--color-accent); text-decoration: underline;">Clawmark</a> &mdash; an open-source Rust binary with a built-in AI model for semantic search. When Claude saves something, Clawmark stores it in a local SQLite database and indexes it by meaning. When Claude searches, Clawmark finds relevant memories even if the words don't match exactly.
      </p>
      <p style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.7;">
        It connects to Claude Desktop through <a href="https://modelcontextprotocol.io" style="color: var(--color-accent); text-decoration: underline;">MCP</a> (Model Context Protocol) &mdash; the standard way to extend what Claude can do. No hacks. No workarounds. Just a clean integration that Anthropic designed for exactly this purpose.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1rem;">
        Stop re-explaining yourself<br/>to your own AI.
      </h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); margin-bottom: 2rem;">
        Free forever. Your data stays local.
      </p>
      <a href="https://github.com/jackccrawford/Geniuz/releases/latest/download/Geniuz.dmg" id="cta-download" class="btn btn-accent" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none; margin-bottom: 0.75rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download for Mac
      </a>
      <div>
        <a href="https://github.com/jackccrawford/Geniuz" style="font-size: 0.8125rem; color: var(--color-ink-tertiary); text-decoration: none;" onmouseenter="this.style.color='var(--color-accent)'" onmouseleave="this.style.color='var(--color-ink-tertiary)'">or view on GitHub</a>
      </div>
      <p style="font-size: 0.8125rem; color: var(--color-ink-quaternary); margin-top: 1.5rem;">MIT License &middot; Free forever &middot; Your data stays on your computer</p>
    </div>
  </section>

  <Footer />

  <script>
    // Platform detection — show the right install path
    const isMac = navigator.platform.toUpperCase().includes('MAC') || navigator.userAgent.includes('Macintosh');
    const macSections = document.querySelectorAll('[data-platform="mac"]');
    const linuxSections = document.querySelectorAll('[data-platform="linux"]');

    if (!isMac) {
      // Non-Mac: swap hero and CTA download buttons to point to CLI install
      document.querySelectorAll('a[href*="Geniuz.dmg"]').forEach(el => {
        el.href = '#install';
        el.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg> Install via CLI';
      });
    }
  </script>

</Layout>
