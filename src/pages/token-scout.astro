---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Token Scout | Free and cheap LLM inference, found live."
  description="28+ free LLM models right now. Token Scout discovers them in real time across OpenRouter, Ollama, and local networks. Dynamic pricing, compatibility filtering, cost control. Stop paying for inference your agent can get for free."
>

  <Nav currentPage="token-scout" />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 40px;">
    <div class="container-narrow" style="text-align: center;">
      <div style="margin-bottom: 1.25rem;">
        <img src="/images/token-scout-icon-color.svg" alt="Token Scout" style="height: 80px; display: inline-block;" />
      </div>
      <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-ink-quaternary); margin-bottom: 1rem;">Open source &middot; MIT license &middot; Rust CLI + MCP server</div>
      <h1 style="font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        Free and cheap LLM inference.<br/><span style="color: var(--color-accent);">Found live. Routed safely.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.6; max-width: 560px; margin: 0 auto 1.25rem;">
        There are 28+ free models on OpenRouter right now &mdash; including Qwen3 Coder 480B, Nemotron 120B, and a 1M-context Qwen3.6 Plus. Tomorrow the list will be different. Token Scout discovers them in real time so your agent always routes to the cheapest safe option.
      </p>
      <p style="font-size: 1rem; color: var(--color-ink-tertiary); line-height: 1.6; max-width: 560px; margin: 0 auto 2rem;">
        600+ models across OpenRouter, Groq, Cerebras, Mistral, GitHub, Google, and your local Ollama network. Dynamic pricing. Compatibility filtering. One tool.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/token-scout" class="btn btn-accent" style="padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none;">View on GitHub</a>
      </div>
    </div>
  </section>

  <!-- What it does -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Stop paying for inference your agent can get for free.</h2>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Find free models &mdash; right now, not last week</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">token_scout</span>(query="reasoning code")</div>
          <div style="color: #a1a1aa;">&rarr; Qwen3 Coder 480B (free), Qwen3.6 Plus 1M context (free), DeepSeek R1 (free)...</div>
          <div style="height: 0.5rem;"></div>
          <div style="color: #71717a;">Live results. These models are free today. Tomorrow the list changes.</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Set a cost ceiling &mdash; never overspend</div>
        <div class="code-block">
          <div style="color: #71717a;">TOKEN_SCOUT_MAX_COST=0 &nbsp;&nbsp;&nbsp;&nbsp;# free models only</div>
          <div style="color: #71717a;">TOKEN_SCOUT_MAX_COST=0.001 # free + cheap (~$1/M tokens)</div>
          <div style="height: 0.5rem;"></div>
          <div style="color: #71717a;">Your agent can't accidentally route to a $15/M model.</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Route safely &mdash; compatibility filtering prevents broken calls</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">token_scout</span>(query="reasoning", require={'{"reasoning_format": "inline_tags", "min_context": 32000}'})</div>
          <div style="color: #a1a1aa;">&rarr; 33 compatible models. No context clipping. No tag corruption.</div>
        </div>
      </div>

      <div>
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Your local GPUs count too</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">token_scout</span>(query="fast", prefer="speed")</div>
          <div style="color: #a1a1aa;">&rarr; Llama 3.1 8B on Groq (free), Qwen3 8B on your GPU (free, unlimited)...</div>
          <div style="height: 0.5rem;"></div>
          <div style="color: #71717a;">Ollama instances on your network are discovered automatically. Zero cost.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Providers -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem; text-align: center;">Three discovery layers. One query.</h2>
      <p style="font-size: 0.9375rem; color: var(--color-ink-tertiary); text-align: center; margin-bottom: 2rem;">Token Scout combines cloud, local, and fallback discovery &mdash; every query reflects what's available right now.</p>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 0.9375rem;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-border);">
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600;">Layer</th>
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600;">What it discovers</th>
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600;">How</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">OpenRouter Live</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">600+ models with real-time pricing. 28+ free right now.</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-tertiary);">GET /api/v1/models &mdash; no key needed</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Ollama Constellation</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Every model on your local network. Free, unlimited.</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-tertiary);">Probes configured hosts via /api/tags</td>
            </tr>
            <tr>
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Static Fallback</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Groq, Cerebras, Mistral, GitHub, Google &mdash; curated free tiers.</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-tertiary);">Always available, even offline</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p style="font-size: 0.875rem; color: var(--color-ink-quaternary); text-align: center; margin-top: 1.25rem;">Free models on OpenRouter change hourly. Token Scout catches them as they appear and disappear.</p>
    </div>
  </section>

  <!-- Quick start -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">Five minutes to first query</h2>

      <div style="max-width: 560px; margin: 0 auto;">
        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Install (Rust CLI or Python MCP)</div>
          <div class="code-block">
            <div><span style="color: #4ade80;">$</span> git clone https://github.com/jackccrawford/token-scout.git</div>
            <div><span style="color: #4ade80;">$</span> cd token-scout</div>
            <div><span style="color: #4ade80;">$</span> cargo build --release &nbsp;&nbsp;<span style="color: #71717a;"># Rust (recommended)</span></div>
            <div><span style="color: #4ade80;">$</span> pip install -e . &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color: #71717a;"># or Python MCP server</span></div>
          </div>
        </div>

        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Add your keys (whichever providers you have)</div>
          <div class="code-block">
            <div><span style="color: #4ade80;">$</span> export GROQ_API_KEY=gsk_...</div>
            <div><span style="color: #4ade80;">$</span> export OPENROUTER_API_KEY=sk-or-...</div>
            <div><span style="color: #4ade80;">$</span> export GITHUB_TOKEN=ghp_...</div>
          </div>
        </div>

        <div style="margin-bottom: 2rem;">
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Add to Claude Code</div>
          <div class="code-block">
            <div><span style="color: #4ade80;">$</span> claude mcp add token-scout -- token-scout</div>
          </div>
        </div>

        <div>
          <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Or add to Claude Desktop</div>
          <div class="code-block">
            <div style="color: #71717a;">// claude_desktop_config.json</div>
            <div>{</div>
            <div>&nbsp;&nbsp;"mcpServers": {</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;"token-scout": {</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"command": "<span style="color: #4ade80;">token-scout</span>"</div>
            <div>&nbsp;&nbsp;&nbsp;&nbsp;}</div>
            <div>&nbsp;&nbsp;}</div>
            <div>}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">Why not just search OpenRouter yourself?</h2>
      <div style="max-width: 560px; margin: 0 auto;">
        <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.5rem;">
          You can. But your AI agent can't browse a website. Token Scout gives your agent the same market awareness you have &mdash; what's free, what's cheap, what just appeared, what disappeared since yesterday. Plus three things OpenRouter's UI doesn't tell you:
        </p>
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Compatibility prevents three common failures</div>
        <div style="display: grid; gap: 0.75rem;">
          <div style="padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px;">
            <div style="font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem;">Broken tool calls</div>
            <div style="font-size: 0.875rem; color: var(--color-ink-secondary);">Anthropic, OpenAI, and Ollama handle function calling differently. Token Scout profiles the format so your agent never routes to an incompatible model.</div>
          </div>
          <div style="padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px;">
            <div style="font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem;">Context clipping</div>
            <div style="font-size: 0.875rem; color: var(--color-ink-secondary);">Sending 200K tokens to a 32K model isn't graceful degradation &mdash; it's data loss. The <code>min_context</code> filter prevents it.</div>
          </div>
          <div style="padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px;">
            <div style="font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem;">Reasoning tag corruption</div>
            <div style="font-size: 0.875rem; color: var(--color-ink-secondary);">Claude, DeepSeek R1, and Qwen3 all expose thinking differently. Mixing formats mid-workflow corrupts the session. Token Scout profiles <code>reasoning_format</code> so you match correctly.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why not bookmarks -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">The free tier changes every hour.</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 540px; margin: 0 auto;">
        A 480B model that's free right now costs $2.20/M tokens tomorrow. A new model drops with a 48-hour promotional window. Groq adds Kimi K2 at 1 trillion parameters &mdash; free. If your agent is hardcoding model IDs or reading from a static config, it's paying for inference it could get for free.
      </p>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 540px; margin: 1.25rem auto 0;">
        Token Scout checks the market on every query. Your agent always routes to the cheapest option that's compatible with the task. The savings compound &mdash; 50 subagent calls a day on free models instead of paid ones adds up fast.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 60px; padding-bottom: 80px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1rem;">
        Your agent is paying retail.<br/><span style="color: var(--color-accent);">It doesn't have to.</span>
      </h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); margin-bottom: 2rem;">
        One tool. Five minutes. Free and cheap inference, found live.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/token-scout" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: var(--color-surface-dark); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: opacity 0.15s;" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
      <p style="font-size: 0.8125rem; color: var(--color-ink-quaternary); margin-top: 1.5rem;">MIT License &middot; Rust + Python &middot; Works with Claude Code, OpenClaw, LangChain, CrewAI &amp; any MCP client</p>
    </div>
  </section>

  <Footer />

</Layout>
