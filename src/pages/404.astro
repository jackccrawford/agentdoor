---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - AgentDoor" description="That page doesn't exist. Head back to AgentDoor.">

  <Nav currentPage="home" />

  <div class="section" style="padding-top: 140px; padding-bottom: 80px;">
    <div class="container-narrow" style="max-width: 720px;">
      <h1 style="font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 700; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1.5rem;">Page not found</h1>
      <p style="color: var(--color-ink-secondary); margin-bottom: 2rem; font-size: 1.0625rem;">The page you're looking for doesn't exist or has been moved.</p>

      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="/" class="btn btn-accent" style="text-decoration: none;">Back to home</a>
        <a href="/geniuz/" class="btn" style="text-decoration: none; background-color: transparent; border: 1px solid var(--color-ink-tertiary); color: var(--color-ink-secondary);">See the tools</a>
      </div>
    </div>
  </div>

  <Footer />

</Layout>
