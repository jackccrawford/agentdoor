---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Clawmark | Persistent memory for OpenClaw agents"
  description="Your OpenClaw agent learns things. Then the session ends and it's gone. Clawmark fixes that. Semantic search replaces markdown grep."
>

  <Nav />

  <!-- Hero -->
  <section class="section" style="padding-top: 140px; padding-bottom: 40px;">
    <div class="container-narrow" style="text-align: center;">
      <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-ink-quaternary); margin-bottom: 1rem;">Open source &middot; MIT license &middot; Works alongside OpenClaw</div>
      <h1 style="font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.035em; margin-bottom: 1.25rem;">
        Persistent memory for<br/><span style="color: var(--color-accent);">OpenClaw agents.</span>
      </h1>
      <p style="font-size: 1.125rem; color: var(--color-ink-secondary); line-height: 1.6; max-width: 480px; margin: 0 auto 2rem;">
        Your agent learns things. Then the session ends and it's gone.<br/>Clawmark fixes that.
      </p>
      <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/clawmark" class="btn btn-accent" style="padding: 0.875rem 1.75rem; font-size: 1rem; text-decoration: none;">View on GitHub</a>
      </div>
    </div>
  </section>

  <!-- The problem -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">The problem</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 600px; margin: 0 auto 1.5rem; text-align: center;">
        OpenClaw stores memory in markdown files. <code style="font-family: var(--font-mono); font-size: 0.875rem; background: var(--color-surface-subtle); padding: 0.15em 0.4em; border-radius: 4px;">MEMORY.md</code> for long-term, daily logs for everything else. Both get read into the prompt on every turn.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; margin-top: 2rem;">
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Search doesn't work.</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Finding an insight from two weeks ago means grepping markdown. No semantic search. Just keywords that happen to match.</div>
        </div>
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Context bloats.</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">Every interaction appends to the daily log. Files grow. Prompts grow. Token costs grow. Eventually the context fills and history is lost.</div>
        </div>
        <div style="padding: 1.25rem; border: 1px solid var(--color-border); border-radius: 8px;">
          <div style="font-weight: 600; margin-bottom: 0.5rem;">Sessions don't connect.</div>
          <div style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;">What your agent learned at 2am is gone by morning. Last week's breakthrough? Buried in a dated file, never loaded.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- The fix -->
  <section class="section" style="padding-top: 40px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">The fix</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); text-align: center; margin-bottom: 2rem;">Two commands. Then your memory works.</p>
      <div class="code-block" style="max-width: 520px; margin: 0 auto;">
        <div><span class="code-comment"># Install</span></div>
        <div><span style="color: #4ade80;">$</span> cargo install clawmark</div>
        <div style="height: 1rem;"></div>
        <div><span class="code-comment"># Import your OpenClaw memory</span></div>
        <div><span style="color: #4ade80;">$</span> clawmark migrate</div>
        <div style="height: 0.5rem;"></div>
        <div><span class="code-comment"># Enable semantic search</span></div>
        <div><span style="color: #4ade80;">$</span> clawmark backfill</div>
      </div>
      <p style="font-size: 0.9375rem; color: var(--color-ink-tertiary); text-align: center; margin-top: 1.25rem;">
        Your <code style="font-family: var(--font-mono); font-size: 0.8125rem; background: rgba(0,0,0,0.05); padding: 0.15em 0.4em; border-radius: 4px;">MEMORY.md</code> and daily logs become searchable signals. Semantic search replaces grep.
      </p>
    </div>
  </section>

  <!-- What it looks like -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">What it looks like</h2>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Save what you learned</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">$</span> clawmark signal -c "Token validation was running before the refresh check. Swapped lines 42-47 in auth.rs." -g "fix: auth token refresh order"</div>
          <div style="color: #4ade80;">&#x2705; Signal 98672A90 saved</div>
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Find it later &mdash; by meaning, not keywords</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">$</span> clawmark tune "authentication middleware"</div>
          <div style="color: #a1a1aa;">98672A90 | 2026-03-19 18:47 | fix: auth token refresh order (0.487)</div>
        </div>
        <div style="font-size: 0.8125rem; color: var(--color-ink-tertiary); margin-top: 0.5rem; padding-left: 0.25rem;">
          Searched for "authentication middleware." Found "token validation" and "refresh check" &mdash; because the meaning overlaps, even though the words don't.
        </div>
      </div>

      <div style="margin-bottom: 2rem;">
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Full content when you need it</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">$</span> clawmark tune --full "auth"</div>
          <div style="color: #a1a1aa;">98672A90 | 2026-03-19 18:47 | fix: auth token refresh order</div>
          <div style="color: #71717a; padding-left: 2ch;">Token validation was running before the refresh check.</div>
          <div style="color: #71717a; padding-left: 2ch;">Swapped lines 42-47 in auth.rs.</div>
        </div>
      </div>

      <div>
        <div style="font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-tertiary); margin-bottom: 0.75rem;">Check your station</div>
        <div class="code-block">
          <div><span style="color: #4ade80;">$</span> clawmark status</div>
          <div style="color: #a1a1aa;">Station: ~/.clawmark/station.db</div>
          <div style="color: #a1a1aa;">Signals: 847</div>
          <div style="color: #a1a1aa;">Embeddings: 847/847 cached</div>
          <div style="color: #4ade80;">Semantic search: ready</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Performance comparison -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 2rem; text-align: center;">OpenClaw memory vs. Clawmark</h2>
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 0.9375rem;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-border);">
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600;"></th>
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600; color: var(--color-ink-tertiary);">OpenClaw</th>
              <th style="text-align: left; padding: 0.75rem 1rem; font-weight: 600; color: var(--color-accent);">Clawmark</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Search</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Keyword grep</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">Semantic (BERT)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Search time</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Grows with file count</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">&lt;1 second</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Storage</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Markdown files</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">SQLite</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Threading</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">None</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">Parent-child chains</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Cross-session</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Today + yesterday</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">Full history</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-border);">
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Dependencies</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">Node.js 22+, pnpm</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">None (static binary)</td>
            </tr>
            <tr>
              <td style="padding: 0.75rem 1rem; font-weight: 500;">Binary size</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink-secondary);">&mdash;</td>
              <td style="padding: 0.75rem 1rem; color: var(--color-ink);">31MB</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px;">
    <div class="container-narrow">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.5rem; text-align: center;">How it works</h2>
      <div style="max-width: 600px; margin: 0 auto;">
        <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; margin-bottom: 1.25rem;">
          Clawmark is a compiled Rust binary backed by SQLite. No Node.js. No runtime dependencies. No background services. No account. No cloud.
        </p>
        <div class="code-block" style="margin-bottom: 1.5rem;">
          <div style="color: #a1a1aa;">Agent &rarr; clawmark (Rust binary) &rarr; SQLite</div>
        </div>
        <ul style="list-style: none; padding: 0; display: grid; gap: 1rem;">
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">01</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;"><strong style="color: var(--color-ink);">Signals</strong> store insights with a gist (compressed index) and content (full detail). Content can be inline, from a file, or piped from stdin.</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">02</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;"><strong style="color: var(--color-ink);">Semantic search</strong> uses a built-in BERT model (384 dimensions, 50+ languages). Auto-downloads on first use. No API keys.</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">03</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;"><strong style="color: var(--color-ink);">Threads</strong> link signals together. Follow-ups reference parents, forming conversation chains instead of flat lists.</span>
          </li>
          <li style="display: flex; gap: 0.75rem; align-items: baseline;">
            <span style="color: var(--color-accent); font-weight: 700; flex-shrink: 0;">04</span>
            <span style="font-size: 0.9375rem; color: var(--color-ink-secondary); line-height: 1.6;"><strong style="color: var(--color-ink);">Runs on anything.</strong> Pi 5, Mac, Linux server. 31MB static binary. <code style="font-family: var(--font-mono); font-size: 0.8125rem;">cargo install</code> and done.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Works alongside OpenClaw -->
  <section class="section" style="padding-top: 60px; padding-bottom: 60px; background: var(--color-surface-subtle);">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1.25rem;">Works alongside OpenClaw</h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); line-height: 1.7; max-width: 520px; margin: 0 auto 1.5rem;">
        Clawmark doesn't replace OpenClaw. It runs alongside it. Your agent keeps using OpenClaw for channels, tools, heartbeat, and skills. Clawmark just fixes the memory.
      </p>
      <div class="code-block" style="max-width: 560px; margin: 0 auto; text-align: left;">
        <div><span class="code-comment"># Add to your agent's skill set</span></div>
        <div><span style="color: #4ade80;">$</span> cp $(clawmark skill --path) ~/.openclaw/skills/clawmark/SKILL.md</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 80px; padding-bottom: 80px;">
    <div class="container-narrow" style="text-align: center;">
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1rem;">
        Your agent is forgetting<br/>right now.
      </h2>
      <p style="font-size: 1rem; color: var(--color-ink-secondary); margin-bottom: 2rem;">
        Two commands and it stops.
      </p>
      <div class="code-block" style="max-width: 400px; margin: 0 auto 2rem; text-align: left;">
        <div><span style="color: #4ade80;">$</span> cargo install clawmark</div>
        <div><span style="color: #4ade80;">$</span> clawmark migrate</div>
        <div><span style="color: #4ade80;">$</span> clawmark backfill</div>
      </div>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="https://github.com/jackccrawford/clawmark" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 1.75rem; background: var(--color-surface-dark); color: white; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 1rem; transition: opacity 0.15s;" onmouseenter="this.style.opacity='0.85'" onmouseleave="this.style.opacity='1'">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
      <p style="font-size: 0.8125rem; color: var(--color-ink-quaternary); margin-top: 1.5rem;">MIT License &middot; Rust &middot; 31MB binary &middot; Runs on Pi 5</p>
    </div>
  </section>

  <Footer />

</Layout>
